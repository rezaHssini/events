{
  "name": "@event/web",
  "private": true,
  "version": "0.1.0",
  "description": "Event web client (React + Vite)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:mobile": "tsc -b && vite build --config vite.config.mobile.ts",
